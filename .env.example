# ============================================================
# OUTREACH AGENT — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your keys
# ============================================================

# --- LLM (Required) ---
GROQ_API_KEY=your_groq_api_key_here

# --- Web Search (Required) ---
# Get free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# --- Lead Scraping (Optional but recommended) ---
# Get key at https://apify.com — free tier available
APIFY_API_KEY=your_apify_api_key_here

# --- Apollo.io for Lead Enrichment (Optional) ---
# Get key at https://apollo.io
APOLLO_API_KEY=your_apollo_api_key_here

# --- Email Sending (Optional) ---
# Gmail App Password — generate at myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# --- Agent Configuration ---
# LLM Models
FAST_MODEL=llama-3.1-8b-instant
SMART_MODEL=llama-3.3-70b-versatile

# Scoring threshold (0-100). Leads below this score are skipped.
LEAD_SCORE_THRESHOLD=65

# Max leads to process per run (cost control)
MAX_LEADS_PER_RUN=20

# Enable human-in-loop review before sending (true/false)
HUMAN_IN_LOOP=true

# Output directory for results
OUTPUT_DIR=data/output
