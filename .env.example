# ============================================================
# RESEARCH OUTREACH AGENT — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your keys
# ============================================================

# --- LLM (Required) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# --- Web Search (Required for real lead discovery) ---
# Get a free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# --- LinkedIn Scraping (Optional — improves lead quality) ---
# Get a key at https://apify.com — free tier available
APIFY_API_KEY=your_apify_api_key_here
# Apify actor used for people search (default is a public LinkedIn search actor)
APIFY_LINKEDIN_ACTOR=harvestapi/linkedin-profile-search

# --- Verified Business Emails (Optional) ---
# Apollo.io — https://apollo.io (free tier). Enables verified work emails.
APOLLO_API_KEY=

# --- Email Sending (Optional — OFF by default) ---
# Gmail App Password — generate at myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Set to true to allow the Sender agent to actually send emails.
ENABLE_EMAIL_SENDING=false

# --- LLM Models ---
FAST_MODEL=llama-3.1-8b-instant
SMART_MODEL=llama-3.3-70b-versatile

# --- Pipeline Configuration ---
# Scoring threshold (0-100). Leads below this score are skipped.
LEAD_SCORE_THRESHOLD=60

# Max leads to process per run (cost control)
MAX_LEADS_PER_RUN=15

# Enable human-in-loop CLI review before sending (true/false)
HUMAN_IN_LOOP=false

# --- Verification ---
# Only keep leads that pass verification (drop unverified). true/false
STRICT_VERIFICATION=false
# Attempt SMTP mailbox probe for emails (slow, can be blocked). true/false
SMTP_PROBE=false

# Output directory for results
OUTPUT_DIR=data/output
